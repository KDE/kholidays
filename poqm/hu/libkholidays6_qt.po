#~ msgid "<p>Select to use Holiday Region</p>"
#~ msgstr "<p>A használandó szabadság régió kiválasztása</p>"

#~ msgid ""
#~ "<p><b>Region:</b> %1<br/><b>Language:</b> %2<br/><b>Description:</b> %3</"
